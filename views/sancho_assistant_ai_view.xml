<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_ai" model="ir.ui.view">
        <field name="name">sale.order.form.ai</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_generate_chat" 
                        string="✨ Generar con IA" 
                        type="object" 
                        class="oe_highlight btn-ai-generate"/>
            </xpath>

            <xpath expr="//notebook" position="before">
                <group>
                    <field name="ai_instruction" 
                           placeholder="Ej: Cliente quiere 2 portátiles y 5 sillas..." 
                           style="background-color: #e6f2ff; padding: 10px; border-radius: 5px;"
                           widget="ai_instruction_trigger"/>
                    
                    <field name="ai_conversation" 
                           readonly="1" 
                           force_save="1"
                           style="background-color: #f9f9f9; border: 1px solid #ccc; padding: 10px; height: 150px; overflow-y: scroll;"/>
                </group>
            </xpath>

        </field>
    </record>

    <record id="view_ai_product_selection_wizard_form" model="ir.ui.view">
        <field name="name">ai.product.selection.wizard.form</field>
        <field name="model">ai.product.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Ambigüedad detectada">
                <sheet>
                    <div class="alert alert-warning" role="alert" style="margin-bottom: 20px;">
                        <strong>⚠️ IA:</strong> He encontrado varios productos similares. 
                        Por favor, confirma cuál deseas añadir al presupuesto.
                    </div>
                    
                    <group>
                        <group>
                            <field name="qty" readonly="1" string="Cantidad solicitada"/>
                        </group>
                        <group>
                            <field name="product_ids" widget="many2many_tags" readonly="1" string="Opciones encontradas"/>
                        </group>
                    </group>

                    <group>
                        <field name="selected_product_id" 
                               options="{'no_create': True, 'no_open': True}" 
                               class="oe_inline"
                               style="font-size: 1.2em; font-weight: bold;"/>
                        
                        <field name="remaining_items_json" invisible="1"/>
                    </group>
                </sheet>

                <footer>
                    <button string="✅ Confirmar y Seguir" 
                            name="action_confirm_selection" 
                            type="object" 
                            class="btn-primary"/>
                    
                    <button string="Cancelar" 
                            name="action_cancel_selection" 
                            type="object" 
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>